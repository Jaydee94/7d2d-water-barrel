<?xml version="1.0" encoding="UTF-8"?>
<configs>
    <!-- Test boost: shorten Dew Collector production cycle for faster local iteration. -->
    <set xpath="/blocks/block[@name='cntDewCollector']/property[@name='MinConvertTime']/@value">1200</set>
    <set xpath="/blocks/block[@name='cntDewCollector']/property[@name='MaxConvertTime']/@value">2400</set>

    <append xpath="/blocks">
        <block name="automatedWaterBarrel">
            <!-- Reuse a valid vanilla loot-container base available in this game version. -->
            <property name="Extends" value="cntGarageStorage" />
            <property name="DescriptionKey" value="automatedWaterBarrelDesc" />
            <property name="Tags" value="WaterStorage,storage" />
            <!-- Use a real player storage layout so the block can be opened reliably. -->
            <property name="LootList" value="playerWoodWritableStorage" />
            <!-- Barrel look based on vanilla cntBarrelPlasticSingle00 visuals. -->
            <property name="Material" value="MFuelBarrelPolymer" />
            <property name="Shape" value="ModelEntity" />
            <property name="Model" value="@:Entities/Industrial/barrelPlasticPrefab.prefab" />
            <property name="Place" value="TowardsPlacerInverted" />
            <property name="CustomIcon" value="cntBarrelPlasticSingle00" />
        </block>
    </append>
</configs>
